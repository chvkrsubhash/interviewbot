# Dependencies
node_modules/
client/node_modules/
server/node_modules/

# Build output
client/dist/

# Environment variables — never commit real credentials
server/.env
server/config/serviceAccountKey.json

# Local Firestore mock DB (dev-only, auto-regenerated on startup)
server/config/firestoreMockDb.json

# SQLite legacy database
server/database.sqlite

# Uploaded files (user-generated content)
server/uploads/*
!server/uploads/.gitkeep

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Vercel
.vercel/
