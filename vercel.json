{
  "version": 2,
  "buildCommand": "npm install --prefix client && npm run build --prefix client",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/server/server.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "server/server.js": {
      "runtime": "@vercel/node@3"
    }
  }
}
