PORT=5000
JWT_SECRET=your-strong-jwt-secret-here

# ─── Razorpay Payment Gateway ────────────────────────────────────────────────
# Get from https://dashboard.razorpay.com → Settings → API Keys
# Use LIVE keys (not test/sandbox) for production
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_live_secret_here

# ─── Firebase / Firestore ────────────────────────────────────────────────────
# Option A: Set these Vercel Environment Variables OR in server/.env
# Get from Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Option B: Place serviceAccountKey.json in server/config/ (local dev only, never commit!)

# ─── Optional: Gemini AI ─────────────────────────────────────────────────────
# GEMINI_API_KEY=your_gemini_api_key_here
